{
  "name": "openai/loan-api-yii2",
  "description": "Loan request processing API built with Yii2",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "yiisoft/yii2": "^2.0.49",
    "yiisoft/yii2-composer": "^2.0"
  },
  "require-dev": {
    "yiisoft/yii2-debug": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "app\\": ""
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "yii\\composer\\Installer::postCreateProject"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
